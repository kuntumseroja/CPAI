# CAPA AI - Environment Variables
# Copy to .env and configure for your environment

# Database (PostgreSQL - used by podman compose)
POSTGRES_USER=capa
POSTGRES_PASSWORD=capa_secret
POSTGRES_DB=capa_ai
DATABASE_URL=postgresql://capa:capa_secret@localhost:5432/capa_ai

# Vector Store
QDRANT_URL=http://localhost:6333

# LLM API Keys (for Claude, GPT-4o when not using vLLM)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: Override config
CAPA_ENVIRONMENT=development
CAPA_DEBUG=true
